{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MAI",
  "version": "0.2.0",
  "identifier": "com.mai.desktop",
  "build": {
    "beforeDevCommand": {
      "script": "pnpm dev --host 0.0.0.0 --port 5173",
      "cwd": "..",
      "wait": false
    },
    "beforeBuildCommand": {
      "script": "pnpm build",
      "cwd": "..",
      "wait": true
    },
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"],
    "externalBin": ["binaries/mai-backend"]
  }
}
