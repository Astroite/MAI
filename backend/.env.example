APP_NAME=MAI

# Default backing store is a SQLite file under the working directory in dev,
# or %APPDATA%/MAI in a packaged build. To use PostgreSQL instead, uncomment
# the DATABASE_URL line below and point it at your instance.
# DATABASE_URL=postgresql+asyncpg://mai:mai_dev_password@localhost:5432/mai

TRACE_PAYLOAD_DIR=trace_payloads
UPLOAD_DIR=uploads
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,tauri://localhost,http://tauri.localhost

# All LLM calls go through LiteLLM. Provide credentials in one of two ways:
#   1. Fill the env vars below (used as the default for any persona without a
#      bound ApiProvider).
#   2. Create an ApiProvider in the UI Settings page and bind it to the
#      persona — those credentials override the env defaults at call time.
# Provider key required depends on the persona's backing_model prefix:
#   openai/<model>      -> OPENAI_API_KEY
#   anthropic/<model>   -> ANTHROPIC_API_KEY
#   gemini/<model>      -> GEMINI_API_KEY
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Optional provider/base-url overrides supported by LiteLLM-compatible setups.
OPENAI_API_BASE=
ANTHROPIC_API_BASE=
