APP_NAME=MAI
DATABASE_URL=postgresql+asyncpg://mai:mai_dev_password@localhost:5432/mai

# Keep true for deterministic local development and tests.
# Set false when at least one persona uses a real LiteLLM model name.
MOCK_LLM=true

TRACE_PAYLOAD_DIR=trace_payloads
UPLOAD_DIR=uploads
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Real model calls are routed through LiteLLM. Set the keys required by the
# provider prefixes used in persona.backing_model, for example:
#   openai/<model>      -> OPENAI_API_KEY
#   anthropic/<model>   -> ANTHROPIC_API_KEY
#   gemini/<model>      -> GEMINI_API_KEY
# The app does not require these variables while MOCK_LLM=true.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Optional provider/base-url overrides supported by LiteLLM-compatible setups.
OPENAI_API_BASE=
ANTHROPIC_API_BASE=
